app = "YOUR_APP_NAME-server"
primary_region = "ord"

[build]
dockerfile = "Dockerfile.prod"

[env]
ENVIRONMENT = "production"
PYTHONPATH = "/app"
IN_DOCKER = "1"

[http_service]
internal_port = 8000
force_https = true

[[http_service.checks]]
grace_period = "10s"
interval = "30s"
method = "GET"
timeout = "5s"
path = "/health"

[[vm]]
memory = "1gb"
cpu_kind = "shared"
cpus = 1

[deploy]
strategy = "immediate" 